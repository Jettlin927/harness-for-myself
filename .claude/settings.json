{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && make lint 2>&1 | tail -20",
            "timeout": 30,
            "statusMessage": "Running lint..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && make check 2>&1 | tail -40",
            "timeout": 120,
            "statusMessage": "Running lint + test..."
          }
        ]
      }
    ]
  }
}
