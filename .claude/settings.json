{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/ts\" && npx eslint src/ tests/ 2>&1 | tail -20",
            "timeout": 30,
            "statusMessage": "Running ESLint..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q '.ts$' && cd \"$CLAUDE_PROJECT_DIR/ts\" && npx tsc --noEmit 2>&1 | tail -20 || true",
            "timeout": 30,
            "statusMessage": "TypeScript type check..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/ts\" && npm run check 2>&1 | tail -40",
            "timeout": 120,
            "statusMessage": "Running lint + build + test..."
          }
        ]
      }
    ]
  }
}
